# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL connection string
# Local:    postgresql://postgres:password@localhost:5432/linkly
# Railway:  automatically set as DATABASE_URL
# Supabase: found in Project Settings → Database → Connection string
DATABASE_URL=postgresql://user:password@localhost:5432/linkly

# Generate a strong random secret:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

# Google OAuth (For Google sign in)
# Get from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Your public domain (no trailing slash). Leave empty to use localhost.
BASE_URL=https://yourdomain.com

# Port (Railway/Render set this automatically)
PORT=3000

# Set to "production" when deploying
NODE_ENV=production
